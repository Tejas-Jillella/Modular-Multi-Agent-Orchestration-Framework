# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Local vLLM inference endpoint
INFERENCE_ENDPOINT=http://inference-svc:8000/v1

# For development/local testing (overrides the K8s service name above)
# INFERENCE_ENDPOINT=http://localhost:8000/v1

# Redis (for the K8s microservices layer, not needed for local development)
REDIS_URL=redis://redis:6379

# Optional: real search API key (leave blank to use MockSearchTool)
# SERPER_API_KEY=your_key_here
